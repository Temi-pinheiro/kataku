{
  "expo": {
    "name": "Kataku",
    "slug": "kataku",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.temitopepinheiro.kataku",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.temitopepinheiro.kataku",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Kataku uses the microphone to hear you speak your answers.",
          "speechRecognitionPermission": "Kataku uses speech recognition to check what you said in the language you are learning."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Kataku records short clips of your answers so you can replay your progress."
        }
      ],
      "expo-sqlite",
      "expo-notifications",
      "expo-speech-transcriber"
    ]
  }
}
